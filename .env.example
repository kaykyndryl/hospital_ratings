# Environment Configuration
# Copy this file to .env and fill in your actual values (if using real CMS API data)

# Optional: CMS API credentials for live Medicare data
# CMS_API_KEY=your_cms_api_key_here
# CMS_API_ENDPOINT=https://data.cms.gov/api/

# Optional: For future Azure integration
# AZURE_SEARCH_ENDPOINT=your_search_endpoint_here
# AZURE_SEARCH_KEY=your_search_key_here
# AZURE_SEARCH_INDEX=hospital_ratings

# COMMENTED OUT: Azure OpenAI Configuration (available in analysis_agent.py)
# Uncomment analysis_agent.py to enable GPT-4o powered analysis
# AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/openai/deployments/gpt-4o/chat/completions?api-version=2025-01-01-preview
# AZURE_OPENAI_API_KEY=your_api_key_here

